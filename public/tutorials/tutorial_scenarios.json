        "command": "PLAY_OLD_CARDS",
        "count": 1,
        "autoEndTurn": true
      }
    },
    "steps": [
      {
        "step": 1,
        "trigger": { "type": "TUTORIAL_START" },
        "action": { "type": "SHOW_MODAL", "text": "よくぞお越しいただきました！\n『Historio』での生存の術をお教えします。\n\n「OK」を押して次へ行きましょう。" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      },
      {
        "step": 2,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "SHOW_MODAL", "text": "あなたの手札にある「豊作」というカードを選択してプレイしてみましょう。" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      },
      {
        "step": 3,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "card_豊作" },
        "completionCondition": { "type": "SELECT_CARD", "cardName": "豊作" }
      },
      {
        "step": 3.5,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "play_button" },
        "completionCondition": { "type": "PLAY_CARD", "cardName": "豊作" }
      },
      {
        "step": 4,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "SHOW_MODAL", "text": "カードのプレイができましたね。\nそれでは右下にある「ターン終了」ボタンを押して、相手にターンを渡しましょう。" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      },
      {
        "step": 5,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "end_turn_button" },
        "completionCondition": { "type": "END_TURN" }
      },
      {
        "step": 6,
        "trigger": { "type": "TURN_START", "player": "human", "round": 2 },
        "action": { "type": "SHOW_MODAL", "text": "あなたの2ターン目です。\nターンが始まると、自動で山札からカードを1枚引きます。\n手札が1枚増えているはずです。" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      },
      {
        "step": 7,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "player-hand-area" },
        "completionCondition": { "type": "CLICK_TARGET" }
      },
      {
        "step": 8,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "SHOW_MODAL", "text": "ところで、このゲームでは意識が高い方が勝利となります。\n意識は互いに15。このままではあなたは勝てません。\nしかし、意識を高めるカードもない……\n\n「予感」をプレイして運命を信じるべきでしょう。" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      },
      {
        "step": 9,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "card_予感" },
        "completionCondition": { "type": "SELECT_CARD", "cardName": "予感" }
      },
      {
        "step": 9.5,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "play_button" },
        "completionCondition": { "type": "PLAY_CARD", "cardName": "予感" }
      },
      {
        "step": 10,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "SHOW_MODAL", "text": "ふむ。「覚醒」を引いたようですね。\nこのカードは効果で意識を1高めることができます。\nこれは勝機です！\n\n「覚醒」をプレイしましょう。" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      },
      {
        "step": 11,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "card_覚醒" },
        "completionCondition": { "type": "SELECT_CARD", "cardName": "覚醒" }
      },
      {
        "step": 11.5,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "play_button" },
        "completionCondition": { "type": "PLAY_CARD", "cardName": "覚醒" }
      },
      {
        "step": 12,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "SHOW_MODAL", "text": "意識が16になりましたね。\nこのゲームはあなたか相手のデッキがなくなったときに意識が比較されます。次の相手のターンが始まると、相手はカードを引きデッキが0枚になります。\n\nあなたはもう待つだけで勝てますよ！\n\nさぁ、ターン終了を押して相手の逃れ得ぬ運命を見届けましょう！" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      },
      {
        "step": 13,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "end_turn_button" },
        "completionCondition": { "type": "END_TURN" }
      }
    ]
  },
  "SCENARIO_CONSCIOUSNESS_ZERO": {
    "firstPlayer": "HUMAN",
    "enableMulligan": false,
    "shuffleDeck": false,
    "npcScript": {
      "1": {
        "command": "PLAY_OLD_CARDS",
        "count": 2,
        "autoEndTurn": true
      },
      "2": {
        "command": "PLAY_OLD_CARDS",
        "count": 2,
        "autoEndTurn": true
      }
    },
    "steps": [
      {
        "step": 1,
        "trigger": { "type": "TUTORIAL_START" },
        "action": { "type": "SHOW_MODAL", "text": "このチュートリアルでは、カードの種類と「意識」を下げる方法をお教えします。" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      },
      {
        "step": 2,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "SHOW_MODAL", "text": "まずは「戦士」を配置しましょう。これは「財」カード。\n場に残り、毎ターン相手の意識を下げます。\n\n耐久値(🛡️)がなくなると場からはいなくなりますがね。" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      },
      {
        "step": 3,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "card_戦士" },
        "completionCondition": { "type": "SELECT_CARD", "cardName": "戦士" }
      },
      {
        "step": 3.5,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "play_button" },
        "completionCondition": { "type": "PLAY_CARD", "cardName": "戦士" }
      },
      {
        "step": 4,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "SHOW_MODAL", "text": "去年のように決着を待つのも悪くないですが、自らケリを付ける方が確実ですからね。\nもう一枚の「戦士」も並べてしまいましょう。" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      },
      {
        "step": 5,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "card_戦士" },
        "completionCondition": { "type": "SELECT_CARD", "cardName": "戦士" }
      },
      {
        "step": 5.5,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "play_button" },
        "completionCondition": { "type": "PLAY_CARD", "cardName": "戦士" }
      },
      {
        "step": 6,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "SHOW_MODAL", "text": "今はターンを終了し、相手の「意識」が下がるのを見届けましょう。" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      },
      {
        "step": 7,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "end_turn_button" },
        "completionCondition": { "type": "END_TURN" }
      },
      {
        "step": 8,
        "trigger": { "type": "TURN_START", "player": "human", "round": 2 },
        "action": { "type": "SHOW_MODAL", "text": "さて、人類らしい高度な戦いを展開しましょう。\n「イデオロギー」カードである「物質主義」を手に入れました。" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      },
      {
        "step": 9,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "SHOW_MODAL", "text": "しかし「物質主義」をプレイするには規模が足りません。\nまずは「事象」カードである「豊作」を使い、自分の規模をプラスしましょう。" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      },
      {
        "step": 10,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "card_豊作" },
        "completionCondition": { "type": "SELECT_CARD", "cardName": "豊作" }
      },
      {
        "step": 10.5,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "play_button" },
        "completionCondition": { "type": "PLAY_CARD", "cardName": "豊作" }
      },
      {
        "step": 11,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "SHOW_MODAL", "text": "この「豊作」のように、事象カードは場に残ることはありません。\n出来事はすぐ過去に打ち捨てられてしまう……\n\nしかし、これで規模が確保できました。「物質主義」を使いましょう。" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      },
      {
        "step": 12,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "card_物質主義" },
        "completionCondition": { "type": "SELECT_CARD", "cardName": "物質主義" }
      },
      {
        "step": 12.5,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "play_button" },
        "completionCondition": { "type": "PLAY_CARD", "cardName": "物質主義" }
      },
      {
        "step": 13,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "SHOW_MODAL", "text": "完璧です。\n思想こそ、人類の人類たり得る理由と言えましょう。\n\nモノは多ければ多いほど良い！\n強欲のままに我らの豊かさを誇示しようではありませんか！" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      },
      {
        "step": 14,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "SHOW_MODAL", "text": "あぁ、そういえば。\n「物質主義」は場に財カードが3枚以上あると相手の意識を1減らせるんですよ。\n\nついでに「農民」でもプレイしましょうか。" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      },
      {
        "step": 15,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "card_農民" },
        "completionCondition": { "type": "SELECT_CARD", "cardName": "農民" }
      },
      {
        "step": 15.5,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "play_button" },
        "completionCondition": { "type": "PLAY_CARD", "cardName": "農民" }
      },
      {
        "step": 16,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "HIGHLIGHT", "targetId": "end_turn_button" },
        "completionCondition": { "type": "END_TURN" }
      },
      {
        "step": 17,
        "trigger": { "type": "TURN_START", "player": "human", "round": 3 },
        "action": { "type": "SHOW_MODAL", "text": "段々と相手の意識も下がってきました。\n放っておいても負けることは無いでしょう……\n\nしかし、相手の運命に終止符を打つこともできる。" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      },
      {
        "step": 18,
        "trigger": { "type": "PREVIOUS_STEP_COMPLETE" },
        "action": { "type": "SHOW_MODAL", "text": "後のことはあなたに任せましょう。\n闘争心に溢れたあなたと民ならば、きっと勝利を掴めるでしょうからね。\n\nそれではまた来年。" },
        "completionCondition": { "type": "INPUT_REQUIRED" }
      }
    ]
  },
